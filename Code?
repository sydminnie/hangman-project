import random
lives = 6
print("Let's play hangman!")
words = ['hangman', 'mango', 'restaurant', 'goat', 'happy', 'horse', 'moose']
word = random.choice(words)
guessedChar = [] #empty array
won = False

while True:
    while won == False and lives > 0:

        print("Guess a letter:")
        guess = input()

        if len(guess) != 1 or not guess.isalpha(): #if guess invalid
            print("Not a valid guess. Please enter a single letter.")
            continue

        if guess in guessedChar:
            print("You already guessed that letter.")
            continue

        guessedChar.append(guess)

        if guess not in word:
            lives -= 1
            print("wrong, lives left:", lives)

        display = "" # reset what is displayed
        for char in word:
            if char in guessedChar:
                display += char
            else:
                display += "_"

        print(display)
        
        if display == word: #user guesses = word
            won = True

    if won:
        print("Winner! The word was:", word)
    else:
        print("Out of lives, game over!")
    print("Want to play again?")
    if(input() == "yes"):
        word = random.choice(words) #reset word, lives, game
        won = False
        guessedChar = []
        print(“New game!”)
        continue
    break #only stops game when when input not “yes”
